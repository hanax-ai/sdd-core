# --- Dependencies ---
node_modules/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Heavy local repository mirrors (register them in knowledge/instructions.md) ---
reference/repos/*
!reference/repos/.gitkeep
projects/*/reference/repos/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp

# --- Conversation sync content (local-only; directory shape and policy are committed) ---
projects/*/conversations/*
!projects/*/conversations/.gitkeep
!projects/*/conversations/SYNC-POLICY.md
conversations/*
!conversations/README.md
!conversations/SYNC-POLICY.md
!conversations/TEMPLATE.md

# --- WIP collaborative content is tracked; only machine-local scratch stays ignored ---
wip/.local/
wip/**/*.tmp
wip/**/generated/

# --- Governance-ops evidence (Article III evidence classes; policy + synthetic templates are committed) ---
# Class 1 (committed): records/README.md (policy), records/templates/** (synthetic only).
# Class 2 (machine-local): everything else under records/ stays ignored by default.
# Class 3 (external): only safe references appear in committed files.
projects/governance-ops/records/*
!projects/governance-ops/records/README.md
!projects/governance-ops/records/templates/
projects/governance-ops/records/templates/*
!projects/governance-ops/records/templates/README.md
!projects/governance-ops/records/templates/*.template.md
