# --- Dependencies ---
node_modules/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Heavy local repository mirrors (register them in knowledge/instructions.md) ---
reference/repos/*
!reference/repos/.gitkeep
projects/*/reference/repos/

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp

# --- Conversation sync content (local-only; directory shape and policy are committed) ---
projects/*/conversations/*
!projects/*/conversations/.gitkeep
!projects/*/conversations/SYNC-POLICY.md
conversations/*
!conversations/README.md
!conversations/SYNC-POLICY.md
!conversations/TEMPLATE.md
